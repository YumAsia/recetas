(activeStep===i?null:i);renderPasos();}function doneStep(i,e){e.stopPropagation();completedSteps.has(i)?completedSteps.delete(i):completedSteps.add(i);if(completedSteps.has(i)&&activeStep===i){var pasos=PASOS[met]||[];activeStep=i+1<pasos.length?i+1:null;}renderPasos();}function renderPro(){var html="<div class='pro-grid'>";PRO.forEach(function(p){html+="<div class='pro-item'><b>"+p[0]+"</b><strong>"+p[1]+"</strong> &#8594; "+p[2]+"</div>";});html+="</div>";document.getElementById("pro-list").innerHTML=html;}function changeMet(){met=document.getElementById("met-sel").value;timerIntervals={};activeStep=null;completedSteps.clear();render();}function changeServings(d){servings=Math.max(1,Math.min(8,servings+d));document.getElementById("cnt").textContent=servings;document.getElementById("srv-lbl").textContent=servings===1?"1 persona":servings+" personas";renderIng();}function render(){renderIng();renderTimings();renderPasos();renderPro();}render();</script></body></html>
